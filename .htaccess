# ===========================================
# Al-Rouby Customs — Server Configuration
# Version: 3.0 | Multi-Page SEO-Optimized
# ===========================================

# --- 1. CORE SETTINGS & SECURITY ---
Options -Indexes
AddDefaultCharset UTF-8
ServerSignature Off

<IfModule mod_headers.c>
    # Security Headers
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
    Header always set X-Permitted-Cross-Domain-Policies "none"

    # Content Security Policy
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://formspree.io; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://formspree.io; frame-ancestors 'self';"

    # Strict Transport Security
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Remove server version info
    Header unset X-Powered-By
    Header unset Server
</IfModule>

# --- 2. URL REWRITE RULES ---
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Force HTTPS
    RewriteCond %{HTTPS} !=on
    RewriteRule ^/?(.*) https://%{SERVER_NAME}/$1 [R=301,L]

    # Remove www
    RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
    RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

    # Add trailing slash to directories (ar/, zh/)
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^(.*[^/])$ /$1/ [L,R=301]

    # Remove index.html from URLs, except the three homepage aliases
    RewriteCond %{REQUEST_URI} !^/(index\.html|ar/index\.html|zh/index\.html)$ [NC]
    RewriteCond %{THE_REQUEST} \s/+.+/index\.html(?:[\s?]|$) [NC]
    RewriteRule ^(.*)index\.html$ /$1 [R=301,L]

    # Old single-page anchor redirects to new pages
    # (In case anyone bookmarked /#services etc.)
    # These are handled client-side by JS, no server redirect needed for hash fragments
</IfModule>

# --- 3. COMPRESSION ---
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml
    AddOutputFilterByType DEFLATE text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE application/xml application/xhtml+xml
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/ttf font/woff font/woff2
</IfModule>

# --- 4. BROWSER CACHING ---
<IfModule mod_expires.c>
    ExpiresActive On

    # Images: 1 year
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"

    # Fonts: 1 year
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"

    # CSS & JS: 1 month
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/manifest+json "access plus 1 week"

    # HTML: 1 hour (allow frequent SEO updates)
    ExpiresByType text/html "access plus 1 hour"

    # XML (sitemap): 1 day
    ExpiresByType application/xml "access plus 1 day"
    ExpiresByType text/xml "access plus 1 day"
</IfModule>

# --- 5. MIME TYPES ---
<IfModule mod_mime.c>
    AddType image/svg+xml .svg
    AddType image/webp .webp
    AddType application/json .json
    AddType application/xml .xml
    AddType application/manifest+json .webmanifest
</IfModule>

# --- 6. CUSTOM ERROR PAGES ---
ErrorDocument 404 /404.html
